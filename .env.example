# ─────────────────────────────────────────────────────────────
# Rufen Campaign — env template. Copy to .env and fill the blanks.
# .env is gitignored; .env.example is committed (no real secrets).
# ─────────────────────────────────────────────────────────────

# ===== ElevenLabs (voice) =====
ELEVENLABS_API_KEY=                 # needs Conversational AI read+write + Phone Numbers scope
ELEVEN_LLM=claude-haiku-4-5         # in-call LLM (id from GET /v1/convai/llm/list)
ELEVEN_AGENT_PHONE_NUMBER_ID=       # after importing the Telnyx number into ElevenLabs (SIP trunk)
# ELEVEN_AGENT_ID is created PER CAMPAIGN at launch — not set here.

# ===== Telnyx (SIP trunk) =====
TELNYX_API_KEY=
TELNYX_FROM_NUMBER=+4934156154530   # DE caller ID (configured on the ElevenLabs SIP number)

# ===== Orchestration LLM (script + extraction generation) =====
ORCHESTRATOR_PROVIDER=anthropic     # anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ===== Temporal =====
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=rufen

# ===== Optional (post-call webhook fallback only) =====
PUBLIC_URL=                          # ngrok https URL, if GET-conversation lacks analysis mid-poll

# ===== Preset (don't touch — docker-compose) =====
DJANGO_SECRET_KEY=__GENERATED__
DJANGO_DEBUG=1
DATABASE_URL=postgres://rufen:rufen@db:5432/rufen
REDIS_URL=redis://redis:6379/0
