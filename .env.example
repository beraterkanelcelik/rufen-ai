# ─────────────────────────────────────────────────────────────
# Rufen AI — environment template. Copy to .env and fill the blanks.
# .env is gitignored; .env.example is committed (no real secrets).
# ─────────────────────────────────────────────────────────────

# ===== YOU PROVIDE (generate these) =====================================

# ElevenLabs API key  →  elevenlabs.io → Settings → API Keys
ELEVENLABS_API_KEY=

# The agent that places the call. Create one (dashboard or API) and paste its id.
# (We can create it together via API in slice 1.)
ELEVEN_AGENT_ID=

# The Telnyx number imported into ElevenLabs as a SIP-trunk phone number.
# ElevenLabs → Agents → Phone Numbers → import → copy the phone_number_id.
ELEVEN_AGENT_PHONE_NUMBER_ID=

# A real phone you will personally answer for the test call (E.164).
TEST_TO_NUMBER=

# ===== NEEDED LATER (not for slice 1) ===================================

# Public HTTPS tunnel to localhost:8000 (ngrok/cloudflared).
# Used for ElevenLabs server-tool + post-call webhook (slices 4+).
PUBLIC_URL=

# Planning-phase LLM (the call-builder interview, slice 6). One of these.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Exact Claude Haiku identifier for the agent's LLM.
# Get it day-of:  GET https://api.elevenlabs.io/v1/convai/llm/list  (xi-api-key)
ELEVEN_LLM=

# Shared secret guarding /api/agent/tool + MCP (slices 4+). Any random string.
RUFEN_SHARED_SECRET=change-me

# ===== PRESET (don't touch — used by docker-compose) ====================
DJANGO_SECRET_KEY=__GENERATED__
DJANGO_DEBUG=1
DATABASE_URL=postgres://rufen:rufen@db:5432/rufen
REDIS_URL=redis://redis:6379/0
